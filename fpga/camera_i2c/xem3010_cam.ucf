NET "hi_inout<13>"	LOC = "T4";

NET "hi_inout<14>"	LOC = "T5";

NET "hi_inout<15>"	LOC = "R5";

NET "hi_muxsel"      LOC = "R9";

NET "i2c_sda"			LOC = "R13" | PULLUP;

NET "i2c_scl"			LOC = "U13" | PULLUP;


#---------------

# PLL Clock pins

#---------------
NET "clk1" LOC = "N9";
NET "clk1" TNM_NET = "clk1";
TIMESPEC "TS_clk1" = PERIOD "clk1" 10.0 ns HIGH 50%;   # 100MHz

NET "clk2" LOC = "P9";
NET "clk2" TNM_NET = "clk2";
TIMESPEC "TS_clk2" = PERIOD "clk2" 41.667 ns HIGH 50%;   # 24MHz


NET "v_sup" LOC = "T1" | IOSTANDARD = LVCMOS33;       # JP3-17 (PWDN)

NET "sioc" LOC = "M1" | IOSTANDARD = LVCMOS33;   # JP3-29
NET "siod" LOC = "L2" | IOSTANDARD = LVCMOS33;   # JP3-31
NET "vsync" LOC = "L1" | IOSTANDARD = LVCMOS33;   # JP3-33
NET "href" LOC = "K2" | IOSTANDARD = LVCMOS33;   # JP3-37
NET "pclk" LOC = "K1" | IOSTANDARD = LVCMOS33 | CLOCK_DEDICATED_ROUTE = FALSE;   # JP3-39
NET "xclk" LOC = "K5" | IOSTANDARD = LVCMOS33;   # JP3-41

NET "p_data[7]" LOC = "K4" | IOSTANDARD = LVCMOS33;   # JP3-43
NET "p_data[6]" LOC = "J6" | IOSTANDARD = LVCMOS33;   # JP3-45
NET "p_data[5]" LOC = "J5" | IOSTANDARD = LVCMOS33;   # JP3-47
NET "p_data[4]" LOC = "J4" | IOSTANDARD = LVCMOS33;   # JP3-49
NET "p_data[3]" LOC = "J1" | IOSTANDARD = LVCMOS33;   # JP3-51
NET "p_data[2]" LOC = "J2" | IOSTANDARD = LVCMOS33;   # JP3-53
NET "p_data[1]" LOC = "H1" | IOSTANDARD = LVCMOS33;   # JP3-57
NET "p_data[0]" LOC = "H2" | IOSTANDARD = LVCMOS33;   # JP3-59

