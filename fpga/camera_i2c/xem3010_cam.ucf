NET "hi_in<3>"			LOC = "V12";

NET "hi_in<4>"			LOC = "R8";

NET "hi_in<5>"			LOC = "T8";

NET "hi_in<6>"			LOC = "V8";

NET "hi_in<7>"			LOC = "V7";

NET "hi_out<0>"		LOC = "V10";

NET "hi_out<1>"		LOC = "V11";

NET "hi_inout<0>"		LOC = "T7";

NET "hi_inout<1>"		LOC = "R7";

NET "hi_inout<2>"		LOC = "V9";

NET "hi_inout<3>"		LOC = "U9";

NET "hi_inout<4>"		LOC = "P11";

NET "hi_inout<5>"		LOC = "N11";

NET "hi_inout<6>"		LOC = "R12";

