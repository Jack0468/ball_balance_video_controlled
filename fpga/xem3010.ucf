# NET "cam_d<2>"   LOC = "XXX" | IOSTANDARD = LVCMOS33;
# NET "cam_d<3>"   LOC = "XXX" | IOSTANDARD = LVCMOS33;
# NET "cam_d<4>"   LOC = "XXX" | IOSTANDARD = LVCMOS33;
# NET "cam_d<5>"   LOC = "XXX" | IOSTANDARD = LVCMOS33;
# NET "cam_d<6>"   LOC = "XXX" | IOSTANDARD = LVCMOS33;
# NET "cam_d<7>"   LOC = "XXX" | IOSTANDARD = LVCMOS33;
# NET "cam_scl"    LOC = "XXX" | IOSTANDARD = LVCMOS33 | PULLUP;
# NET "cam_sda"    LOC = "XXX" | IOSTANDARD = LVCMOS33 | PULLUP;
# NET "cam_reset"  LOC = "XXX" | IOSTANDARD = LVCMOS33;

#-------------------------------
# ADC Pins (ADS1675) - UNMAPPED
#-------------------------------
# Please fill in the LOC pins for your ADC connections
# NET "adc_sclk"   LOC = "XXX" | IOSTANDARD = LVCMOS33;
# NET "adc_cs_n"   LOC = "XXX" | IOSTANDARD = LVCMOS33;
# NET "adc_sdata"  LOC = "XXX" | IOSTANDARD = LVCMOS33;
# NET "x_drive"    LOC = "XXX" | IOSTANDARD = LVCMOS33;
# NET "y_drive"    LOC = "XXX" | IOSTANDARD = LVCMOS33;
